#!/bin/bash

# Dynamically detect integrated monitor
INTEGRADO=$(xrandr --query | grep -E '^eDP|^LVDS' | cut -d" " -f1 | head -n1)
[ -z "$INTEGRADO" ] && INTEGRADO=$(xrandr --query | grep " connected" | cut -d" " -f1 | head -n1)

# Dynamically detect first connected external monitor
EXTERNO=$(xrandr --query | grep " connected" | grep -v "$INTEGRADO" | cut -d" " -f1 | head -n1)

getRes() {
	[ -z "$1" ] && return
	xrandr -q | grep -A 1 "$1" | awk 'FNR == 2 {print $1}'
}

# Ensure LOGINLOG is defined
LOGINLOG="${LOGINLOG:-$HOME/.local/login.log}"

if [ -n "$EXTERNO" ]; then
	echo "External monitor connected: $EXTERNO" >> "$LOGINLOG"
	xrandr --output "$INTEGRADO" \
		--primary \
		--mode $(getRes "$INTEGRADO") \
		--rotate normal \
		--output "$EXTERNO" \
		--mode $(getRes "$EXTERNO") \
		--rotate normal \
		--above "$INTEGRADO" 2>>"$LOGINLOG"
	bspc config top_padding 0
else
	echo "Only integrated monitor connected: $INTEGRADO" >> "$LOGINLOG"
	xrandr --output "$INTEGRADO" \
		--primary \
		--mode $(getRes "$INTEGRADO") \
		--rotate normal 2>>"$LOGINLOG"
	
	# Turn off other outputs that are disconnected
	for output in $(xrandr --query | grep " disconnected" | cut -d" " -f1); do
		xrandr --output "$output" --off 2>>"$LOGINLOG"
	done
fi

# Remove any monitors from bspwm that are no longer connected
for mon in $(bspc query -M --names); do
	if ! xrandr --query | grep -q "^$mon connected"; then
		echo "Removing disconnected monitor from bspwm: $mon" >> "$LOGINLOG"
		bspc monitor "$mon" -r 2>>"$LOGINLOG"
	fi
done
bspc wm -o 2>>"$LOGINLOG"
