#!/bin/sh
WIDTH=$(mediainfo "$1" | awk -F":" '/Width/ {print $2}' | sed -e s/' '//g -e s/pixels//g)

HEIGHT=$(mediainfo "$1" | awk -F":" '/Height/ {print $2}' | sed -e s/' '//g -e s/pixels//g)

ROT=$(mediainfo "$1" | awk -F":" '/Rotation/ {print $2}')

echo $WIDTH $HEIGHT
DIMS=""
if [ $ROT ]; then
  DIMS="$HEIGHT"x"$WIDTH"
else
  DIMS="$WIDTH"x"$HEIGHT"
fi

echo $DIMS

bspc rule -a mpv -o state=floating rectangle="$DIMS"+40+20 2>&1
mpv "$@"
